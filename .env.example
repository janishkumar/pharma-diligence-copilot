# Required for Phase 1 hosted generator (D1 = Anthropic).
ANTHROPIC_API_KEY=

# Required for judge (D6 = OpenAI, must differ from generator family).
OPENAI_API_KEY=

# Not needed for default stack unless using gated HF models.
HF_TOKEN=

# Phase 2 training observability (D4 = TensorBoard; WandB not required).
WANDB_API_KEY=

# Runtime flags
OFFLINE_MODE=0           # set to 1 in Phase 2 to forbid hosted calls
COST_BUDGET_USD=10       # session cost ceiling
